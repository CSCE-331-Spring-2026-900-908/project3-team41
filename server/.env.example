#
# Copy this file to `.env` (not committed) and fill in the values.
#

# Existing server config (if you use it)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=password
# Your Postgres host may require SSL/TLS. Set to `true` if you see pg_hba
# errors like "no encryption" when connecting.
DB_SSL=false

# Google Cloud Translation credentials (required for /api/translate)
# Set to the absolute path or relative path (from the `server/` directory)
# of the service account JSON key file.
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# Optional, but recommended.
# GOOGLE_TRANSLATE_PROJECT_ID=your-gcp-project-id

